# Gambit.csr -- symbols for the Gambit example corpus (namespaces Rules, Engine)

symbol meld:
  id: csr.Rules.meld
  namespace: Rules
  framework_layer: domain
  owning_document: csr.document.Rulebook
  display_name: "meld"
  type: concept
  status: provisional
  definition_home: csr.document.Rulebook@v2#section.1.meld
  definition: "Face-up set of three or more cards of one rank laid from the hand; frozen once laid; scores at end of round."
  definition_hash: auto
