symbol trick:
  id: csr.Rules.trick
  namespace: Rules
  framework_layer: domain
  owning_document: csr.document.Rulebook
  display_name: "trick"
  type: concept
  status: candidate
  definition_home: csr.document.Rulebook@v2#section.2.trick
