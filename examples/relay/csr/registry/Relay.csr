symbol access_token:
  id: csr.Auth.access_token
  namespace: Auth
  framework_layer: domain
  owning_document: csr.document.Auth_Design
  display_name: "access_token"
  type: concept
  status: provisional
  definition_home: csr.document.Auth_Design@v1#section.2.access_token
  definition: "Bearer credential exchanged for a session. Opaque, 32 bytes, 24h rotation. Renamed from api_key in v1."
