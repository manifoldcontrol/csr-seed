symbol session:
  id: csr.Auth.session
  namespace: Auth
  framework_layer: domain
  owning_document: csr.document.Auth_Design
  display_name: "session"
  type: concept
  status: canonical
  definition_home: csr.document.Auth_Design@v1#section.1.session
  definition: "Server-side record binding one client to one scope set for a bounded lifetime. Sole bearer of authenticated identity."
