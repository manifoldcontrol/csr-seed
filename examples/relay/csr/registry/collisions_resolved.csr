# collisions_resolved.csr -- resolved name/concept collisions
#
# Document collisions explicitly when two candidate symbols claim
# overlapping concepts.
#
#   collision my_collision:
#     id: csr.collision.my_collision
#     status: resolved
#     resolution: alias | merge | split | subset_with_added_structure
#     entries: [csr.X.foo, csr.Y.foo]
#     owner: <Namespace>
#     resolved_at: <Doc>_v1
#     note: "..."

collision session_auth_vs_api:
  id: csr.collision.session_auth_vs_api
  status: resolved
  resolution: merge
  entries: [csr.Auth.session, csr.Api.session]
  owner: Auth
  resolved_at: Auth_Design_v1
  note: "Two senses of 'session' (auth identity record vs TCP keep-alive window). Merged on the auth sense; the API-spec sense is deprecated with a superseded_by edge."
